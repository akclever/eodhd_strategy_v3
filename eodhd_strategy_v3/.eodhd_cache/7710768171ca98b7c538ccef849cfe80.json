{"General": {"Code": "IOTR", "Type": "Common Stock", "Name": "iOThree Limited Ordinary Shares", "Exchange": "NASDAQ", "CurrencyCode": "USD", "CurrencyName": "US Dollar", "CurrencySymbol": "$", "CountryName": "USA", "CountryISO": "US", "OpenFigi": "BBG01L5VKXZ5", "ISIN": "KYG4940T1040", "LEI": null, "PrimaryTicker": "IOTR.US", "CUSIP": null, "CIK": null, "EmployerIdNumber": null, "FiscalYearEnd": "March", "IPODate": "2025-04-10", "InternationalDomestic": null, "Sector": "Communication Services", "Industry": "Telecom Services", "GicSector": "Communication Services", "GicGroup": "Telecommunication Services", "GicIndustry": "Diversified Telecommunication Services", "GicSubIndustry": "Alternative Carriers", "HomeCategory": null, "IsDelisted": false, "Description": "iOThree Limited provides maritime digital technologies, satellite connectivity, and digitalization solutions to the maritime industry. The company operates through two segments, Satellite Connectivity Solution, and Digitalization and Other Solutions. It provides satellite connectivity services; and sales and/or leases satellite network equipment and devices for shipboard network management; IT support; shipboard support services for IT and OT applications enablement services, as well as designs digital solutions. The company also offers satellite communications and software solutions. In addition, it provides Just A Really Very Intelligent System (JARVISS) platform that support integrated solutions, asset optimization, and delivery of secured critical applications; and portfolio of digital solutions consist of V.Suite solutions, such as V.SIGHT AI camera surveillance, V.SION AR smart glasses, V.IoT shipboard monitoring and analytics, V.SECURE cybersecurity, and V.WEATHER route optimization, as well as an ERP system, including future ready intelligent digital assistant system (FRIDAY). The company operates in Singapore, Israel, Malaysia, Vietnam, the Republic of Marshall Islands, Thailand, Indonesia, the People's Republic of China, and internationally. The company was incorporated in 2019 and is headquartered in Singapore. iOThree Limited operates as a subsidiary of Io3 Strategic Investments Limited.", "Address": "140 Paya Lebar Road, Singapore, Singapore, 409015", "AddressData": {"Street": "140 Paya Lebar Road", "City": "Singapore", "Country": "Singapore", "ZIP": "409015"}, "Listings": {}, "Officers": {"0": {"Name": "Mr. Eng Chye  Koh", "Title": "CEO & Chairman", "YearBorn": "1978"}, "1": {"Name": "Ms. Fui Chu  Lo", "Title": "Chief Financial Officer", "YearBorn": "1971"}, "2": {"Name": "Mr. Wei Meng  See", "Title": "Chief Technology Officer", "YearBorn": "1977"}, "3": {"Name": "Ms. Hui Cheng  Soh", "Title": "Chief Commercial Officer", "YearBorn": "1982"}}, "Phone": "65 3105 1699", "WebURL": "https://io3.sg", "LogoURL": "", "FullTimeEmployees": 36, "UpdatedAt": "2026-04-12"}, "Highlights": {"MarketCapitalization": 7156352, "MarketCapitalizationMln": 7.1564, "EBITDA": -27861, "PERatio": null, "PEGRatio": null, "WallStreetTargetPrice": null, "BookValue": 1.642, "DividendShare": null, "DividendYield": null, "EarningsShare": -0.2, "EPSEstimateCurrentYear": 0, "EPSEstimateNextYear": 0, "EPSEstimateNextQuarter": 0, "EPSEstimateCurrentQuarter": 0, "MostRecentQuarter": "2025-03-31", "ProfitMargin": -0.0316, "OperatingMarginTTM": -0.0191, "ReturnOnAssetsTTM": -0.0344, "ReturnOnEquityTTM": -0.1275, "RevenueTTM": 12569148, "RevenuePerShareTTM": 5.063, "QuarterlyRevenueGrowthYOY": 0.398, "GrossProfitTTM": 2554515, "DilutedEpsTTM": -0.2, "QuarterlyEarningsGrowthYOY": -0.871}, "Valuation": {"TrailingPE": 0, "ForwardPE": 0, "PriceSalesTTM": 0.5694, "PriceBookMRQ": 1.6986, "EnterpriseValue": 8222269, "EnterpriseValueRevenue": 0.6542, "EnterpriseValueEbitda": 34.1268}, "SharesStats": {"SharesOutstanding": 733326, "SharesFloat": 644046, "PercentInsiders": 0, "PercentInstitutions": 2.257, "SharesShort": null, "SharesShortPriorMonth": null, "ShortRatio": null, "ShortPercentOutstanding": null