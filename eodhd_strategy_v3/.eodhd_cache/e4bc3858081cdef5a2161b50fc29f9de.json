{"General": {"Code": "2718", "Type": "Common Stock", "Name": "Mininglamp Technology", "Exchange": "HK", "CurrencyCode": "HKD", "CurrencyName": "Hong Kong Dollar", "CurrencySymbol": "HK$", "CountryName": "Hong Kong", "CountryISO": "HK", "OpenFigi": "BBG01Y3G0CM4", "ISIN": null, "LEI": null, "PrimaryTicker": null, "CIK": null, "EmployerIdNumber": null, "FiscalYearEnd": "December", "IPODate": null, "InternationalDomestic": null, "Sector": "Technology", "Industry": "Software - Infrastructure", "GicSector": null, "GicGroup": null, "GicIndustry": null, "GicSubIndustry": null, "Description": "Mininglamp Technology, an investment holding company, provides marketing intelligence, operational intelligence, and industry solution services in China. It offers Miaozhen systems, such as Admonitor, a digital advertising monitoring and verification solution; Admonitor OOH, an outdoor advertising monitoring and measurement solution; MixReach, a mature online and offline cross-screen budget allocation and optimization tool; MoFang Pro, a social media marketing monitoring and insights platform; Mingdata DMP, an all-in-one advertising audience targeting and management platform; Social Grow for social media operation and growth; AdEff, an AI-driven AD testing creative testing and optimization platform; Social Grow, a social media marketing management platform; and CDP & MA, a CX-driven data management platform. It also provides Jinshuju, a data platform to collect and manage daily work data; Haoke XM, a user experience analysis tool; Jinshuju AI Exams, an AI-driven online exam software; DeepMiner, a trusted business intelligence agent; and Ming, a one-stop LLM AI plugin. In addition, it offers operational intelligence products, including conversational intelligence, a sales enablement product; Lingting, a hardware to record offline sales and service processes; smart operations solutions, such as Huifu; Mingdiantong, an intelligent construction solution; data-driven store operation; SCM Service comprising Mingqi Mall and Mingqi BoH; Ying Shi Yi, a brand membership GMV growth marketing suite; Meng Shi Yi, a franchise store lifecycle management platform; Mengshiyi, a unified business portal; weibanzhushou, a digital operations management platform; and yiban, an enhanced WeChat editor. The company serves chain retail, home furnishings, beauty and personal care, FMCG, electronics, baby care, medical and aesthetic, e-commerce, automotive, enterprise services, and restaurant outlet industries. The company was founded in 2006 and is headquartered in Ziyang, China.", "Address": "Building 1, Ziyang, China", "AddressData": {"Street": "Building 1", "City": "Ziyang", "Country": "China"}, "Listings": {}, "Officers": {"0": {"Name": "Mr. Minghui  Wu", "Title": "Founder, CEO, CTO & Chairman", "YearBorn": "1983"}, "1": {"Name": "Mr. Ping  Jiang", "Title": "Co-Founder, Executive Director, President & CFO", "YearBorn": "1984"}, "2": {"Name": "Mr. Xin  Fan", "Title": "Joint Company Secretary, Assistant to President and Head of Investment & Financing Department", "YearBorn": "1992"}, "3": {"Name": "Ms. Jie  Zhao", "Title": "Executive Director, Senior VP & Chief Client Officer", "YearBorn": "1970"}, "4": {"Name": "Ms. Qi  Yu", "Title": "Executive Director", "YearBorn": "1982"}, "5": {"Name": "Ms. Lai Kiu  Yim", "Title": "Joint Company Secretary", "YearBorn": "NA"}}, "Phone": "86 40 0893 8989", "WebURL": "https://www.mininglamp.com", "LogoURL": "", "FullTimeEmployees": 1681, "UpdatedAt": "2026-03-19"}, "Highlights": {"MarketCapitalization": 34688196608, "MarketCapitalizationMln": 34688.1966, "EBITDA": -19735000, "PERatio": null, "PEGRatio": null, "WallStreetTargetPrice": null, "BookValue": -270.8132, "DividendShare": null, "DividendYield": null, "EarningsShare": 0, "EPSEstimateCurrentYear": 0, "EPSEstimateNextYear": 0, "EPSEstimateNextQuarter": 0, "EPSEstimateCurrentQuarter": 0, "MostRecentQuarter": "2025-06-30", "ProfitMargin": -0.0686, "OperatingMarginTTM": 0.0122, "Ret