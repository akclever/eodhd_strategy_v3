{"General": {"Code": "CUPR", "Type": "Common Stock", "Name": "Cuprina Holdings (Cayman) Limited Class A Ordinary Shares", "Exchange": "NASDAQ", "CurrencyCode": "USD", "CurrencyName": "US Dollar", "CurrencySymbol": "$", "CountryName": "USA", "CountryISO": "US", "OpenFigi": "BBG01LW6FTB1", "ISIN": "KYG2592E1026", "LEI": null, "PrimaryTicker": "CUPR.US", "CUSIP": null, "CIK": null, "EmployerIdNumber": null, "FiscalYearEnd": "December", "IPODate": "2025-04-10", "InternationalDomestic": null, "Sector": "Healthcare", "Industry": "Medical Instruments & Supplies", "GicSector": "Health Care", "GicGroup": "Health Care Equipment & Services", "GicIndustry": "Health Care Equipment & Supplies", "GicSubIndustry": "Health Care Supplies", "HomeCategory": null, "IsDelisted": false, "Description": "Cuprina Holdings (Cayman) Limited, a biomedical and biotechnology company, focuses on the development and commercialization of products for the management of chronic wounds. The company manufactures and distributes a line of medical grade sterile blowfly larvae bio-dressing products used as a biological debridement tool for chronic wounds under the MEDIFLY brand name. It is also developing collagen dressings, including sponges, particles, and hydrogels using bullfrog collagen derived from the valorization of abattoir waste; and products using medical leeches for wound treatment. The company was founded in 2019 and is based in Singapore. Cuprina Holdings (Cayman) Limited operates as a subsidiary of Cuprina Holding Pte. Ltd.", "Address": "Blk 1090, Singapore, Singapore, 169201", "AddressData": {"Street": "Blk 1090", "City": "Singapore", "Country": "Singapore", "ZIP": "169201"}, "Listings": {}, "Officers": {"0": {"Name": "Mr. Yong Qi  Quek", "Title": "CEO & Director", "YearBorn": "1995"}, "1": {"Name": "Mr. Tat Jing  Chan", "Title": "Chief Financial Officer", "YearBorn": "1992"}, "2": {"Name": "Dr. Ronald  Sherman", "Title": "Medical & Scientific Director", "YearBorn": "NA"}}, "Phone": "65 851