{"General": {"Code": "DGNX", "Type": "Common Stock", "Name": "Diginex Limited Ordinary Shares", "Exchange": "NASDAQ", "CurrencyCode": "USD", "CurrencyName": "US Dollar", "CurrencySymbol": "$", "CountryName": "USA", "CountryISO": "US", "OpenFigi": "BBG01PPMGNL6", "ISIN": "KYG286871044", "LEI": null, "PrimaryTicker": "DGNX.US", "CUSIP": null, "CIK": "0002010499", "EmployerIdNumber": null, "FiscalYearEnd": "March", "IPODate": "2025-01-22", "InternationalDomestic": null, "Sector": "Industrials", "Industry": "Consulting Services", "GicSector": "Information Technology", "GicGroup": "Software & Services", "GicIndustry": "Software", "GicSubIndustry": "Application Software", "HomeCategory": null, "IsDelisted": false, "Description": "Diginex Limited, an investment holding company, engages in the provision of environmental, social, and governance (ESG) reporting solution services, advisory, and developing customization solutions in Hong Kong, the United Kingdom, and the United States. Its suite of products include diginexESG, a cloud based ESG platform that offers end to end reporting from topic discovery, data collection, and collaborative report publishing services; diginexLUMEN that allows companies to execute supply chain risk assessments, and monitoring; diginexAPPRISE, a multilingual application that collects standardized and actionable data related to working conditions directly from workers in supply chains; diginexCLIMATE, a carbon footprint calculator based on the GHG protocols; diginexADVISORY that provides clients strategy and advisory support for credible reporting; and diginexPARTNERS that develops white label versions of diginexESG and diginexLUMEN. The company has a strategic alliance with Sustainability RegTech solutions to deliver technology-driven solutions for sustainable finance, empowering organizations to navigate the evolving landscape of environmental, social, and governance (ESG) requirements. The company has a strategic alliance with EVIDENT Group to enable Diginex's advanced sustainability data capabilities to be embedded directly within EVIDENT's platform for asset managers and investment partner community, addressing the escalating need for verifiable ESG metrics in the rapidly expanding sector of tokenized real-world assets. Diginex Limited was founded in 2020 and is headquartered in London, United Kingdom.", "Address": "25 Wilton Road, London, United Kingdom, SW1V 1LW", "AddressData": {"Street": "25 Wilton Road", "City": "London", "Country": "United Kingdom", "ZIP": "SW1V 1LW"}, "Listings": {}, "Officers": {"0": {"Name": "Mr. Miles Christian  Pelham", "Title": "Founder & Chairman", "YearBorn": "1979"}, "1": {"Name": "Ms. Lubomila  Jordanova", "Title": "CEO & Director", "YearBorn": "NA"}, "2": {"Name": "Mr. Paul Neil  Ewing", "Title": "Chief Financial Officer", "YearBorn": "1973"}, "3": {"Name": "Mr. Jacob  Friedman", "Title": "Chief Operating Officer", "YearBorn": "NA"}, "4": {"Name": "Mr. Graham  Bridges", "Title": "Chief Technology Officer", "YearBorn": "1984"}, "5": {"Name": "Mr. Christian  Thierfelder", "Title": "Chief Information Officer", "YearBorn": "1979"}, "6": {"Name": "Ms. Sandra  Kovacheva", "Title": "Chief Administrative Officer", "YearBorn": "NA"}, "7": {"Name": "Ms. Adele Jessica C. E. Camus-Demarche  N\u00e9e Dyllick-Brenzinger", "Title": "Chief Corporate Affairs & Sustainability Officer", "YearBorn": "1984"}, "8": {"Name": "Mr. Andrew  Harling", "Title": "Chief Commercial Officer", "YearBorn": "NA"}}, "Phone": "44 203 998 0008", "WebURL": "https://www.diginex.com", "LogoURL": "/img/logos/US/DGNX.png", "FullTimeEmployees": 27, "UpdatedAt": "2026-04-12"}, "Highlights": {"MarketCapitalization": 110210856, "MarketCapitalizationMln": 110.2109, "EBITDA": -9584321, "PERatio": null, "PEGRatio": null, "WallStreetTargetPrice": null, "BookValue": 0.054, "DividendShare": null, "DividendYield": null, "EarningsShare": -0.05, "EPSEstimateCurrentYear": 0, "EPSEstimateNextYear": 0, "EPSEstimateNextQuarter"