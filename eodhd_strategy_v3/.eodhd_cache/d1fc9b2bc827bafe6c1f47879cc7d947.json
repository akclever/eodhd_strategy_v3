{"General": {"Code": "80941", "Type": "Common Stock", "Name": "China Mobile Limited", "Exchange": "HK", "CurrencyCode": "HKD", "CurrencyName": "Hong Kong Dollar", "CurrencySymbol": "HK$", "CountryName": "Hong Kong", "CountryISO": "HK", "OpenFigi": "BBG01GXJSWZ6", "ISIN": null, "LEI": null, "PrimaryTicker": null, "CIK": null, "EmployerIdNumber": null, "FiscalYearEnd": "December", "IPODate": null, "InternationalDomestic": null, "Sector": "", "Industry": "", "GicSector": null, "GicGroup": null, "GicIndustry": null, "GicSubIndustry": null, "Description": "China Mobile Limited provides telecommunications and information related services in Mainland China and Hong Kong. The company offers voice, data, broadband, dedicated lines, internet data center, cloud computing, IoT, and other services for the customer, home, business, and new markets. It also provides design and consulting, communication engineering construction, planning, and facilities construction; and equipment maintenance services. In addition, the company engages in the IT system operation; platform research and development; provision of digital data solutions and digital content operation support and services; system integration and development; network engineering and operation and maintenance services, as well as provision of network planning and optimization and training services and information services; digital communication product design and sales; banking and non-banking finance; mobile cloud R&D, operation and support; electronic payment, e-commerce, and Internet-related; investment management; and provision of computer system integration, construction, maintenance, and related technology development services. Further, it involved in the infrastructure project construction; centralized park and data center operation; roaming; and engineering activities. The company was formerly known as China Mobile (Hong Kong) Limited and changed its name to China Mobile Limited in May 2006. China Mobile Limited was incorporated in 1997 and is based in Beijing, China. China Mobile Limited is a subsidiary of China Mobile Hong Kong (BVI) Limited.", "Address": "No. 29 Financial Street, Beijing, China, 100033", "AddressData": {"Street": "No. 29 Financial Street", "City": "Beijing", "Country": "China", "ZIP": "100033"}, "Listings": {}, "Officers": {"0": {"Name": "Mr. Ronghua  Li", "Title": "CFO & Executive Director", "YearBorn": "1966"}, "1": {"Name": "Mr. Limin  Wang", "Title": "Executive Director", "YearBorn": "1969"}, "2": {"Name": "Mr. Dong  Zhang", "Title": "Deputy General Manager", "YearBorn": "1969"}, "3": {"Name": "Mr. Huidi  Li", "Title": "Deputy General Manager", "YearBorn": "1969"}, "4": {"Name": "Mr. Zhongyue  Chen", "Title": "Executive Chairman", "YearBorn": "1971"}, "5": {"Name": "Mr. Yuting  Hu", "Title": "Accounting Supervisor", "YearBorn": "1979"}, "6": {"Name": "Ms. Wai Lan  Wong FCIS, FCS", "Title": "Company Secretary", "YearBorn": "NA"}, "7": {"Name": "Mr. Jian Jun  Cheng", "Title": "Deputy General Manager", "YearBorn": "1972"}}, "Phone": "852 3121 8888", "WebURL": "https://www.chinamobileltd.com", "LogoURL": "", "FullTimeEmployees": 455405, "UpdatedAt": "2026-03-19"}, "Highlights": {"MarketCapitalization": 1723317000000, "MarketCapitalizationMln": 1723317, "EBITDA": 296198995968, "PERatio": null, "PEGRatio": null, "WallStreetTargetPrice": 88, "BookValue": 64.72, "DividendShare": 4.952, "DividendYield": 0.0708, "EarningsShare": 4.8, "EPSEstimateCurrentYear": 0, "EPSEstimateNextYear": 0, "EPSEstimateNextQuarter": 0, "EPSEstimateCurrentQuarter": 0, "MostRecentQuarter": "2025-03-31", "ProfitMargin": 0.1368, "OperatingMarginTTM": 0.1305, "ReturnOnAssetsTTM": 0.0454, "ReturnOnEquityTTM": 0.1046, "RevenueTTM": 1043966984192, "RevenuePerShareTTM": 48.364, "QuarterlyRevenueGrowthYOY": 0.025, "GrossProfitTTM": 305466015744, "DilutedEpsTTM": 4.8, "QuarterlyEarningsGrowthYOY": 0.011}, "Valuation": {"TrailingPE": 0, "ForwardPE": 0, "PriceSalesTTM": 0, "PriceBookMRQ": 0, "En