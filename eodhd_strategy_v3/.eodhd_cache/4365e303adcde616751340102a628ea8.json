{"General": {"Code": "VIVO", "Type": "Common Stock", "Name": "VivoPower PLC", "Exchange": "NASDAQ", "CurrencyCode": "USD", "CurrencyName": "US Dollar", "CurrencySymbol": "$", "CountryName": "USA", "CountryISO": "US", "OpenFigi": "BBG00FNFTYM7", "ISIN": null, "LEI": null, "PrimaryTicker": null, "CUSIP": null, "CIK": null, "EmployerIdNumber": null, "FiscalYearEnd": "June", "IPODate": "1992-02-26", "InternationalDomestic": null, "Sector": "Technology", "Industry": "Software - Infrastructure", "GicSector": null, "GicGroup": null, "GicIndustry": null, "GicSubIndustry": null, "HomeCategory": null, "IsDelisted": false, "Description": "VivoPower PLC, together with its subsidiaries, provides energy solutions for customized and ruggedized fleet applications, battery and microgrids, and solar and critical power technology and services. It operates through Electric Vehicles, Sustainable Energy Solutions, Solar Development, and Digital Assets segments. The Electric Vehicles segment offers ruggedized battery-powered Electric Vehicle (EV) solutions, including conversion kits for fleet owners in the mining, agriculture, energy utility, defense, police, government, public transport, humanitarian, and game safari industries. It also offers ruggedized or customized on-road applications; public utility vehicle electric powertrain conversion kits for the jeepneys; and OEM light utility pickup trucks under the Tembo Tuskers brand name, as well as EV charging solutions for home and commercial applications. The Sustainable Energy Solutions segment engages in the design, evaluation, sale, and implementation of renewable energy infrastructure. The Solar Development segment develops solar projects. The Digital Assets segment engages in digital asset mining activities. It operates in Australia, Canada, the Netherlands, the United Kingdom, the United States, the United Arab Emirates, and the Philippines. The company was formerly known as VivoPower International PLC and changed its name to VivoPower PLC in March 2026. VivoPower PLC was founded in 2014 and is headquartered in London, the United Kingdom.", "Address": "Blackwell House, London, United Kingdom, EC2V 5AE", "AddressData": {"Street": "Blackwell House", "City": "London", "Country": "United Kingdom", "ZIP": "EC2V 5AE"}, "Listings": {}, "Officers": {"0": {"Name": "Mr. Tser Fah Chin", "Title": "Co-Founder, Executive Chairman & CEO", "YearBorn": "1973"}, "1": {"Name": "Mr. Chris J. Mallios", "Title": "Chief Operating Officer", "YearBorn": "1971"}, "2": {"Name": "Mr. Alex  Cuppage", "Title": "Chief Investment Officer", "YearBorn": "NA"}, "3": {"Name": "Ms. Jacqui  Johnson", "Title": "Global Human Resource Director", "YearBorn": "1966"}, "4": {"Name": "Mr. Shane  Whelan", "Title": "Chief Real Estate Officer", "YearBorn": "NA"}}, "Phone": "44 203 667 5158", "WebURL": "https://vivopower.com", "LogoURL": "", "FullTimeEmployees": 184, "UpdatedAt": "2026-04-14"}, "Highlights": {"MarketCapitalization": 42815120, "MarketCapitalizationMln": 42.8151, "EBITDA": -8267000, "PERatio": null, "PEGRatio": null, "WallStreetTargetPrice": null, "BookValue": 1.304, "DividendShare": null, "DividendYield": null, "EarningsShare": -2.17, "EPSEstimateCurrentYear": 0, "EPSEstimateNextYear": 0, "EPSEstimateNextQuarter": 0, "EPSEstimateCurrentQuarter": 0, "MostRecentQuarter": "2024-06-30", "ProfitMargin": 0, "OperatingMarginTTM": -0.0052, "ReturnOnAssetsTTM": -0.081, "ReturnOnEquityTTM": 0, "RevenueTTM": 61000, "RevenuePerShareTTM": 0.009, "QuarterlyRevenueGrowthYOY": 0.476, "GrossProfitTTM": 11000, "DilutedEpsTTM": -2.17, "QuarterlyEarningsGrowthYOY": 0}, "Valuation": {"TrailingPE": 0, "ForwardPE": 0, "PriceSalesTTM": 701.8872, "PriceBookMRQ": 2.6419, "EnterpriseValue": 76050929, "EnterpriseValueRevenue": 1246.7365, "EnterpriseValueEbitda": -4.11}, "SharesStats": {"SharesOutstanding": 16790245, "SharesFloat": 9748050, "PercentInsiders": 25.533, "PercentInstitutions": 4.62, "SharesShort": null, "SharesShortPriorMonth": null, "Short